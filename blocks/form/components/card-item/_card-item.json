{
  "definitions": [
    {
      "title": "Card item",
      "id": "card-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/fd/components/form/panelcontainer/v1/panelcontainer",
            "template": {
              "jcr:title": "Card item",
              "fieldType": "panel",
              "minOccur": 1,
              "fd:viewType": "card-item",
              "cardImage": {
                "sling:resourceType": "core/fd/components/form/image/v1/image",
                "fieldType": "image",
                "jcr:title": "Card Image",
                "altText": "Credit card"
              },
              "cardName": {
                "sling:resourceType": "core/fd/components/form/text/v1/text",
                "fieldType": "plain-text",
                "jcr:title": "Card Name",
                "value": "Card Name"
              },
              "cardTagline": {
                "sling:resourceType": "core/fd/components/form/text/v1/text",
                "fieldType": "plain-text",
                "jcr:title": "Tagline",
                "value": "Best Card for Rewards & Offers"
              },
              "rewardsRate": {
                "sling:resourceType": "core/fd/components/form/text/v1/text",
                "fieldType": "plain-text",
                "jcr:title": "Rewards Rate",
                "value": "Upto 10X CashPoints"
              },
              "rewardsDescription": {
                "sling:resourceType": "core/fd/components/form/text/v1/text",
                "fieldType": "plain-text",
                "jcr:title": "Rewards Description",
                "value": "₹150 spent = 1 Reward Point"
              },
              "joiningFee": {
                "sling:resourceType": "core/fd/components/form/text/v1/text",
                "fieldType": "plain-text",
                "jcr:title": "Joining Fee",
                "value": "Joining/Renewal Fees - ₹500/-"
              },
              "selectCard": {
                "name": "selectCard",
                "sling:resourceType": "core/fd/components/form/radiobutton/v1/radiobutton",
                "fieldType": "radio-group",
                "jcr:title": "Select",
                "enum": [
                  "selected"
                ],
                "enumNames": [
                  "Select this card"
                ],
                "type": "string"
              }
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "card-item",
      "fields": [
        {
          "component": "tab",
          "label": "Basic",
          "name": "basic"
        },
        {
          "...": "../../models/form-common/_basic-input-fields.json#/fields"
        },
        {
          "component": "tab",
          "label": "Repeat Panel",
          "name": "repeat"
        },
        {
          "component": "boolean",
          "name": "repeatable",
          "label": "Make panel repeatable",
          "valueType": "boolean"
        },
        {
          "component": "number",
          "name": "minOccur",
          "label": "Minimum repetitions",
          "valueType": "number",
          "description": "Minimum number of times the panel appears on the form",
          "condition": {
            "===": [
              {
                "var": "repeatable"
              },
              true
            ]
          }
        },
        {
          "component": "number",
          "name": "maxOccur",
          "label": "Maximum repetitions",
          "valueType": "number",
          "placeholder": "No Limit",
          "description": "Maximum number of times the panel can appear on the form. No value indicates no limit.",
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "repeatable"
                  },
                  true
                ]
              },
              {
                "!==": [
                  {
                    "var": "variant"
                  },
                  "noButtons"
                ]
              }
            ]
          }
        },
        {
          "component": "select",
          "name": "variant",
          "label": "Variant",
          "options": [
            {
              "name": "No Actions",
              "value": "noButtons"
            },
            {
              "name": "Add & Delete Buttons",
              "value": "addDeleteButtons"
            }
          ],
          "value": "addDeleteButtons",
          "condition": {
            "===": [
              {
                "var": "repeatable"
              },
              true
            ]
          }
        },
        {
          "component": "text",
          "name": "repeatAddButtonLabel",
          "label": "Add Button Label",
          "valueType": "string",
          "value": "Add",
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "variant"
                  },
                  "addDeleteButtons"
                ]
              },
              {
                "===": [
                  {
                    "var": "repeatable"
                  },
                  true
                ]
              }
            ]
          }
        },
        {
          "component": "text",
          "name": "repeatDeleteButtonLabel",
          "label": "Delete Button Label",
          "valueType": "string",
          "value": "Delete",
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "variant"
                  },
                  "addDeleteButtons"
                ]
              },
              {
                "===": [
                  {
                    "var": "repeatable"
                  },
                  true
                ]
              }
            ]
          }
        },
        {
          "...": "../../models/form-common/_help-container.json#/fields"
        }
      ]
    }
  ]
}